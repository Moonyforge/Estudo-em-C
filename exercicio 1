Exercício 1 – Nome e idade
Peça ao usuário:nome e idade
#include <stdio.h>

int main(){
    char nome[50];
    int idade;
    
    printf("Qual e o seu nome?\n",nome);
    scanf("%s",&nome);
    
    printf("\nQual e a sua idade? \n",idade );
    scanf("%d",&idade);
 
    printf("Ola %s , você tem %d anos",nome,idade);
}

