#include <stdio.h>

int main(){
    
    int num=10;
    char letra='b';
    float num2=3.15;
    
    printf("%d \n",letra);//mostra o valor na tabela ascii
    printf("%c \n",letra);
    printf("%f\n%d \n",num2,num); //imprime dois numero
    printf("num+5:%d \n",num+5); //fez uma soma
    
    
    return 0;
}

#include <stdio.h>

int main(){
    char nome[50];
    char sobrenome[50];
    int idade;
    float altura;
    int anoNascimento;
    int anoAtual=2026;
    
    printf("Digite seu nome:\n");
    scanf("%s",&nome);
  
 
    printf("\nDigite seu sobrenome:");
    scanf("%s",&sobrenome);
  
    
    
    printf("\n Digite sua idade:");
    scanf("%d",&idade);
  
    
    printf("\n Digite sua altura:");
    scanf("%f",&altura);
    
    anoNascimento=idade-anoAtual;
    printf("ano de nascimento: %d \n",anoNascimento);

    
    printf("----Informações--- \n");
    printf("nome completo: %s %s \n",nome,sobrenome);
    printf("idade:%d \n",idade);
    printf("altura:%.2f \n",altura);
    printf("ano nascimento:%d",anoNascimento);
    return 0;
}
